{
    "name": "mhpdigital/cross-tenant-security-bundle-example",
    "description": "Example Symfony app demonstrating mhpdigital/cross-tenant-security-bundle",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": ">=8.1",
        "mhpdigital/cross-tenant-security-bundle": "*@dev",
        "doctrine/doctrine-bundle": "^2.11",
        "doctrine/orm": "^2.17",
        "symfony/dotenv": "^6.4",
        "symfony/framework-bundle": "^6.4",
        "symfony/security-bundle": "^6.4",
        "symfony/yaml": "^6.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0",
        "symfony/phpunit-bridge": "^6.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
